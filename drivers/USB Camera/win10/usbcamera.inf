LoadOrderGroup = Base

[USBCAMERA.Files.Ext]
UsbCamera.sys;=1

[USBCAMERA64.Files.Ext]
UsbCamera64.sys;=1

[USBCAMERA.AddReg]
; Deprecating - do not use in new apps to identify a usbcamera driver
HKR,,DevLoader,,*ntkern
HKR,,NTMPDriver,,%SysFile%
; You may optionally include a check for DriverBase in your application to check for a usbcamera driver
HKR,,DriverBase,,%SysFile%
HKR,"Parameters","MaximumTransferSize",0x10001,4096
HKR,"Parameters","DebugLevel",0x10001,2
HKR,,FriendlyName,,%USBCAMERA_Description%

[USBCAMERA64.AddReg]
; Deprecating - do not use in new apps to identify a usbcamera driver
HKR,,DevLoader,,*ntkern
HKR,,NTMPDriver,,%SysFile64%
; You may optionally include a check for DriverBase in your application to check for a usbcamera driver
HKR,,DriverBase,,%SysFile64%
HKR,"Parameters","MaximumTransferSize",0x10001,4096
HKR,"Parameters","DebugLevel",0x10001,2
HKR,,FriendlyName,,%USBCAMERA_Description%

[USBCAMERA.AddReg.Guid]
HKR,,DriverGUID,,%USBCAMERA.GUID%
HKR,,Exclusive,0x10001,1



